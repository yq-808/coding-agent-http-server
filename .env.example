HOST=127.0.0.1
PORT=8787

# Optional auth for HTTP requests.
# If set, callers must pass Authorization: Bearer <token>
# HTTP_AUTH_TOKEN=change-me

# Default provider adapter.
AGENT_PROVIDER=claude

# Optional runtime defaults.
# AGENT_DEFAULT_CWD=/Users/yongqiwu/code
AGENT_DEFAULT_MODEL=claude-opus-4-6[1m]
# AGENT_MAX_THINKING_TOKENS=2048
# AGENT_DEFAULT_ALLOWED_TOOLS=Skill,Bash,Read,Write
# AGENT_DEFAULT_TOOLS_PRESET=claude_code
AGENT_DEFAULT_SETTING_SOURCES=user

# JSON payload limit for request body parser.
REQUEST_JSON_LIMIT=2mb

# Optional session state directory.
# Default is ~/.coding-agent-http-server
# SESSION_STATE_DIR=/Users/yongqiwu/.coding-agent-http-server

# Skip provider executable check at startup.
# SKIP_PROVIDER_CHECK=1
